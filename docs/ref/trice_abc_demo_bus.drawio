        <mxCell id="10" value="&lt;div style=&quot;text-align:center;&quot;&gt;&lt;b&gt;BcSim byte bus&lt;/b&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;abc.bus + abc.log&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;pure binary framed Trice byte stream; no Trice-specific logic inside BcSim&lt;br/&gt;&lt;span style=&quot;font-size:13px;color:#475569;&quot;&gt;self echo suppressed by remembering own write offsets&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2f7;strokeColor=#64748b;strokeWidth=2;fontSize=17;fontColor=#1f2937;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="330" y="290" width="760" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;demo command set&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;cmd:setLeds&lt;/font&gt; &amp;nbsp;8-bit mask&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;cmd:getLeds&lt;/font&gt; &amp;nbsp;request&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;cmd:setKey&lt;/font&gt; &amp;nbsp;counted bytes&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;cmd:logState&lt;/font&gt; &amp;nbsp;local effect&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;cmd:divide&lt;/font&gt; &amp;nbsp;2 floats&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;abc:LedsState&lt;/font&gt; / &lt;font face=&quot;monospace&quot;&gt;DivideResult&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontSize=14;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="235" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="&lt;b&gt;stamp routing demo&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;low stamp bits select:&lt;/font&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;0x0001 → N7_bi&lt;/font&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;0x0002 → N8_bi&lt;/font&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;0x0004 → N9_bi&lt;/font&gt;&lt;br/&gt;ABC still broadcasts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e9f5c9;strokeColor=#84cc16;strokeWidth=2;fontSize=14;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1120" y="290" width="245" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="&lt;b&gt;shared NodeLib runtime&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;TriceWriteDeviceCgo()&lt;/font&gt;&lt;br/&gt;↓&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;bcSimWrite()/bcSimRead()&lt;/font&gt;&lt;br/&gt;↓&lt;br/&gt;COBS frame collector&lt;br/&gt;↓&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;TriceParseRecord()&lt;/font&gt;&lt;br/&gt;↓&lt;br/&gt;&lt;font face=&quot;monospace&quot;&gt;TriceResolveAbc()/Log()&lt;/font&gt;&lt;br/&gt;↓&lt;br/&gt;handler or demo printer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0ecff;strokeColor=#a78bfa;strokeWidth=2;fontSize=14;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
