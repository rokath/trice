        </mxCell>
        <mxCell id="14" value="&lt;b&gt;Node roles&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;span style=&quot;display:inline-block;border:2px solid #eab308;border-radius:999px;padding:2px 14px;background:#fef3c7;&quot;&gt;tx&lt;/span&gt; &amp;nbsp; send only&lt;br/&gt;&lt;span style=&quot;display:inline-block;border:2px solid #38bdf8;border-radius:999px;padding:2px 14px;background:#dbeafe;&quot;&gt;rx&lt;/span&gt; &amp;nbsp; receive only&lt;br/&gt;&lt;span style=&quot;display:inline-block;border:2px solid #22c55e;border-radius:999px;padding:2px 14px;background:#d1fae5;&quot;&gt;bi&lt;/span&gt; &amp;nbsp; both directions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=2;fontSize=14;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
