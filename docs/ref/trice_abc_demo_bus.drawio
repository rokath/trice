        <mxCell id="3" value="Nine small processes share one protocol-neutral byte bus; NodeLib keeps the normal Trice TX/RX path visible without embedded hardware." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1530" height="28" as="geometry"/>
        </mxCell>
