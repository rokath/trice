  <diagram id="diagram1" name="Trice ABC core workflow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="Trice ABC: command name → compact record → selected local handler" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1420" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="First-reader view: the command string stays in TIL data; the transport carries only ID, optional stamp, and optional payload." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1450" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="&lt;b&gt;Asynchronous&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#475569;&quot;&gt;sender emits a record&lt;br/&gt;and continues immediately&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;strokeWidth=2;fontSize=16;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="&lt;b&gt;Broadcast&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#475569;&quot;&gt;zero, one, or many receivers&lt;br/&gt;may observe the same record&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;strokeWidth=2;fontSize=16;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="110" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="&lt;b&gt;Commands&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#475569;&quot;&gt;selected receivers run&lt;br/&gt;compiled local handlers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;strokeWidth=2;fontSize=16;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="110" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="&lt;b&gt;ABC is not RPC by itself&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:13px;color:#475569;&quot;&gt;addressing, ACKs, retries, auth, timeouts&lt;br/&gt;and return values are application policy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5efe6;strokeColor=#f59e0b;strokeWidth=2;fontSize=16;fontColor=#1f2937;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="110" width="520" height="70" as="geometry"/>
        </mxCell>
